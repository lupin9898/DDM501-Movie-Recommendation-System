# ════════════════════════════════════════════════════════════════════════════
# Movie Recommendation System — Environment Variables
# ════════════════════════════════════════════════════════════════════════════
# 1. Copy this file:  cp .env.example .env
# 2. Replace every "changeme" with a real value before running docker compose
# 3. Never commit your .env file
# ════════════════════════════════════════════════════════════════════════════

# ── API Image ─────────────────────────────────────────────────────────────────
# Leave unset to build from local Dockerfile (default for local dev).
# Set to a registry image to skip the build step (e.g. ghcr.io/org/recsys-api:sha)
# API_IMAGE=recsys-api:local

# ── Host Paths (bind-mounted into containers) ────────────────────────────────
# Default to repo-relative ./data and ./artifacts. Override for CI/prod to point
# at persistent host dirs (e.g. $HOME/recsys-data, $HOME/recsys-artifacts).
# The API, Airflow, and Evidently all mount these exact paths so that training
# (host OR Airflow) and serving share one filesystem — restart api after train
# to pick up the new model.
# RECSYS_DATA_DIR=./data
# RECSYS_ARTIFACTS_DIR=./artifacts

# ── Recommendation System ─────────────────────────────────────────────────────
RECSYS_MODEL_VERSION=lightfm_v1
RECSYS_IMPLICIT_THRESHOLD=3.5
# LightFM hybrid hyperparameters
RECSYS_LIGHTFM_NO_COMPONENTS=64
RECSYS_LIGHTFM_LOSS=warp
RECSYS_LIGHTFM_LEARNING_RATE=0.05
RECSYS_LIGHTFM_EPOCHS=30
RECSYS_LIGHTFM_NUM_THREADS=4
RECSYS_LIGHTFM_TEST_SIZE=0.2
RECSYS_LIGHTFM_SPLIT_SEED=42
RECSYS_LOG_LEVEL=info

# ── MLflow ────────────────────────────────────────────────────────────────────
# Inside Docker network:  http://mlflow:5000
# From host browser:      http://localhost:5000
RECSYS_MLFLOW_TRACKING_URI=http://mlflow:5000
RECSYS_MLFLOW_EXPERIMENT_NAME=movielens-recommendation

# ── PostgreSQL (MLflow + Airflow backend) ──────────────────────────────────────
POSTGRES_PASSWORD=changeme          # REQUIRED — change before first run

# ── MinIO (MLflow artifact store) ─────────────────────────────────────────────
# S3 API:   http://localhost:9000   (also used by host training workflow)
# Console:  http://localhost:9001
MINIO_ROOT_USER=minioadmin
MINIO_PASSWORD=changeme             # REQUIRED — change before first run

# ── Grafana ───────────────────────────────────────────────────────────────────
# UI: http://localhost:3000  (login: admin / GRAFANA_PASSWORD)
GRAFANA_PASSWORD=changeme           # REQUIRED — change before first run

# ── Airflow ───────────────────────────────────────────────────────────────────
# UI: http://localhost:8080  (login: admin / AIRFLOW_ADMIN_PASSWORD)
AIRFLOW_ADMIN_PASSWORD=changeme     # REQUIRED — change before first run

# Fernet key — encrypts Airflow connection secrets in DB
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=46BKJoQYlPPOexq0OhDZnIlNepKFf87WFwLbe4bDCKs=  # DEV ONLY — regenerate for prod

# Secret key for Airflow webserver sessions
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_SECRET_KEY=changeme         # REQUIRED — change before first run
