# Recommendation System Environment Variables
# Copy to .env and fill in values

# Dataset
RECSYS_DATASET_NAME=ml-25m
RECSYS_MIN_USER_RATINGS=20
RECSYS_MIN_ITEM_RATINGS=10

# Model
RECSYS_MODEL_VERSION=als_v1
RECSYS_IMPLICIT_THRESHOLD=3.5

# ALS hyperparameters
RECSYS_ALS_FACTORS=100
RECSYS_ALS_REGULARIZATION=0.05
RECSYS_ALS_ITERATIONS=30
RECSYS_ALS_ALPHA=40.0

# MLflow
RECSYS_MLFLOW_TRACKING_URI=sqlite:///mlflow.db
RECSYS_MLFLOW_EXPERIMENT_NAME=movielens-recommendation

# API
RECSYS_API_HOST=0.0.0.0
RECSYS_API_PORT=8000
RECSYS_LOG_LEVEL=info
